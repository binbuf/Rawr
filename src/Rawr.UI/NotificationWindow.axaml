<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Rawr.ViewModels"
        mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="150"
        x:Class="Rawr.NotificationWindow"
        x:DataType="vm:NotificationViewModel"
        Title="Rawr Notification"
        Width="300" Height="150"
        SystemDecorations="None"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur">

    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}" 
            BorderBrush="{DynamicResource SystemControlForegroundAccentBrush}" 
            BorderThickness="1" 
            CornerRadius="8" 
            Padding="10">
        <Grid RowDefinitions="Auto, *, Auto">
            <StackPanel Grid.Row="0">
                <TextBlock Text="Reminder" FontWeight="Bold" FontSize="12" Foreground="Gray" />
                <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="16" TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Time}" FontSize="14" />
                <TextBlock Text="{Binding Location}" FontSize="12" FontStyle="Italic" TextWrapping="Wrap" IsVisible="{Binding Location, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>

            <Button Grid.Row="2" Content="Dismiss" Command="{Binding DismissCommand}" HorizontalAlignment="Right" />
        </Grid>
    </Border>
</Window>
