<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Rawr.App"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcon Icon="/Assets/dinosaur.ico" ToolTipText="Rawr">
            <TrayIcon.Menu>
                <NativeMenu>
                    <NativeMenuItem Header="Dashboard" Click="OnDashboardClick" />
                    <NativeMenuItem Header="Sync Now" Click="OnSyncNowClick" />
                    <NativeMenuItemSeparator />
                    <NativeMenuItem Header="Settings" Click="OnSettingsClick" />
                    <NativeMenuItem Header="Exit" Click="OnExitClick" />
                </NativeMenu>
            </TrayIcon.Menu>
        </TrayIcon>
    </TrayIcon.Icons>
</Application>