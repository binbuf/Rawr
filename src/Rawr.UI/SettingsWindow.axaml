<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Rawr.ViewModels"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="450"
        x:Class="Rawr.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Rawr Settings"
        Icon="/Assets/dinosaur.ico"
        Width="600" Height="500"
        WindowStartupLocation="CenterScreen">

  <Design.DataContext>
    <vm:SettingsViewModel />
  </Design.DataContext>

  <DockPanel LastChildFill="True" Margin="10">
    <!-- Bottom Action Bar -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
      <Button Command="{Binding SaveCommand}" Content="Save" />
    </StackPanel>

    <TabControl>
      <!-- General Tab -->
      <TabItem Header="General">
        <StackPanel Spacing="10" Margin="10">
          <CheckBox IsChecked="{Binding Config.General.StartWithOS, Mode=TwoWay}" Content="Start with OS" />
          <StackPanel Orientation="Horizontal" Spacing="10">
            <TextBlock VerticalAlignment="Center" Text="Missed Event Threshold (minutes):" />
            <NumericUpDown Value="{Binding Config.General.MissedEventThresholdMinutes, Mode=TwoWay}" Minimum="1" Maximum="1440" />
          </StackPanel>
          <Separator Margin="0,10" />
          <TextBlock Text="Maintenance" FontWeight="Bold" />
          <Button Command="{Binding ResetDataCommand}" Content="Reset Calendar Data" Background="Firebrick" Foreground="White" />
        </StackPanel>
      </TabItem>

      <!-- Calendar Tab -->
      <TabItem Header="Calendar">
        <Grid RowDefinitions="Auto, Auto, *">
          <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
             <Button Command="{Binding AddSourceCommand}" Content="Add Source" />
             <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                 <TextBlock Text="Look Ahead (Hours):" VerticalAlignment="Center"/>
                 <NumericUpDown Value="{Binding Config.Calendar.LookAheadHours, Mode=TwoWay}" Minimum="1" Maximum="168" />
             </StackPanel>
          </StackPanel>

          <StackPanel Grid.Row="1" Spacing="5" Margin="0,0,0,10">
            <CheckBox IsChecked="{Binding Config.Calendar.AlertBeforeEvent, Mode=TwoWay}" Content="Alert before event starts" />
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="25,0,0,0"
                        IsVisible="{Binding Config.Calendar.AlertBeforeEvent}">
                <TextBlock Text="Minutes before:" VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding Config.Calendar.AlertBeforeEventMinutes, Mode=TwoWay}" Minimum="1" Maximum="120" Width="120" />
            </StackPanel>
          </StackPanel>

          <DataGrid Grid.Row="2" ItemsSource="{Binding CalendarSources}" AutoGenerateColumns="False" CanUserResizeColumns="True">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Name" Binding="{Binding Name, Mode=TwoWay}" Width="*" />
              <DataGridTextColumn Header="URL" Binding="{Binding Uri, Mode=TwoWay}" Width="2*" />
              <DataGridTextColumn Header="Color" Binding="{Binding Color, Mode=TwoWay}" Width="Auto" />
              <DataGridCheckBoxColumn Header="Enabled" Binding="{Binding Enabled, Mode=TwoWay}" Width="Auto" />
              <DataGridTemplateColumn Width="Auto">
                  <DataGridTemplateColumn.CellTemplate>
                      <DataTemplate>
                          <Button Content="Remove" 
                                  Command="{Binding $parent[Window].((vm:SettingsViewModel)DataContext).RemoveSourceCommand}" 
                                  CommandParameter="{Binding .}" />
                      </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <!-- Voice Tab -->
      <TabItem Header="Voice">
        <StackPanel Spacing="10" Margin="10">
          <TextBlock Text="Voice Settings" FontWeight="Bold" />
          
          <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="Voice:" VerticalAlignment="Center" Width="60"/>
              <ComboBox ItemsSource="{Binding AvailableVoices}" SelectedItem="{Binding Config.Voice.VoiceId, Mode=TwoWay}" Width="200" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="Rate:" VerticalAlignment="Center" Width="60"/>
              <Slider Value="{Binding Config.Voice.Rate, Mode=TwoWay}" Minimum="0.5" Maximum="2.0" Width="200" />
              <TextBlock Text="{Binding Config.Voice.Rate, StringFormat='{}{0:F1}'}" VerticalAlignment="Center" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="Volume:" VerticalAlignment="Center" Width="60"/>
              <Slider Value="{Binding Config.Voice.Volume, Mode=TwoWay}" Minimum="0" Maximum="100" Width="200" />
              <TextBlock Text="{Binding Config.Voice.Volume}" VerticalAlignment="Center" />
          </StackPanel>

          <Button Command="{Binding TestVoiceCommand}" Content="Test Voice" />
        </StackPanel>
      </TabItem>

      <!-- Notifications Tab -->
      <TabItem Header="Notifications">
        <StackPanel Spacing="10" Margin="10">
          <TextBlock Text="Popup Settings" FontWeight="Bold" />
          
          <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="Position:" VerticalAlignment="Center" Width="120"/>
              <ComboBox ItemsSource="{Binding AvailablePopupPositions}" SelectedItem="{Binding Config.Notifications.Position, Mode=TwoWay}" Width="150" />
          </StackPanel>

          <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="Duration (sec):" VerticalAlignment="Center" Width="120"/>
              <NumericUpDown Value="{Binding Config.Notifications.DurationSeconds, Mode=TwoWay}" Minimum="0" Maximum="60" Width="150" />
          </StackPanel>
          <TextBlock Text="Set to 0 to keep open until dismissed." FontStyle="Italic" FontSize="11" Margin="130,0,0,0" />
          
          <CheckBox IsChecked="{Binding Config.Notifications.HideOnFullscreen, Mode=TwoWay}" Content="Hide popup when a fullscreen app is active" Margin="0,10,0,0" />

          <Separator Margin="0,10" />

          <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock Text="Alert Flash Duration (sec):" VerticalAlignment="Center" Width="160"/>
              <NumericUpDown Value="{Binding Config.Notifications.AlertFlashDurationSeconds, Mode=TwoWay}" Minimum="0" Maximum="300" Width="150" />
          </StackPanel>
          <TextBlock Text="How long the tray icon flashes on alert. Set to 0 for indefinite." FontStyle="Italic" FontSize="11" Margin="170,0,0,0" />

          <CheckBox IsChecked="{Binding Config.Notifications.ShowLocalTimezone, Mode=TwoWay}" Content="Show local timezone in notification popup" Margin="0,10,0,0" />
        </StackPanel>
      </TabItem>

      <!-- Interval Schedule Tab -->
      <TabItem Header="Interval Schedule">
        <ScrollViewer>
          <StackPanel Spacing="10" Margin="10">
            <CheckBox IsChecked="{Binding Config.TimeAwareness.Enabled, Mode=TwoWay}" Content="Enable Interval Announcements" />
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock VerticalAlignment="Center" Text="Interval (minutes):" Width="120" />
              <NumericUpDown Value="{Binding Config.TimeAwareness.IntervalMinutes, Mode=TwoWay}" Minimum="1" Maximum="1440" Width="150" />
            </StackPanel>
            
            <Separator Margin="0,10" />
            <TextBlock Text="Active Hours" FontWeight="Bold" />
            <TextBlock Text="Set the time range for each day when announcements should be active." FontStyle="Italic" FontSize="11" />
            
            <ItemsControl ItemsSource="{Binding IntervalSchedule}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="120, Auto, Auto, Auto, Auto" Margin="0,5">
                    <CheckBox Grid.Column="0" Content="{Binding Day}" IsChecked="{Binding IsEnabled, Mode=TwoWay}" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="From:" VerticalAlignment="Center" Margin="10,0" IsEnabled="{Binding IsEnabled}" />
                    <TimePicker Grid.Column="2" SelectedTime="{Binding StartTime, Mode=TwoWay}" IsEnabled="{Binding IsEnabled}" ClockIdentifier="24HourClock" />
                    <TextBlock Grid.Column="3" Text="To:" VerticalAlignment="Center" Margin="10,0" IsEnabled="{Binding IsEnabled}" />
                    <TimePicker Grid.Column="4" SelectedTime="{Binding EndTime, Mode=TwoWay}" IsEnabled="{Binding IsEnabled}" ClockIdentifier="24HourClock" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </ScrollViewer>
      </TabItem>
    </TabControl>
  </DockPanel>
</Window>
